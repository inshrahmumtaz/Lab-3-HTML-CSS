@inherits LayoutComponentBase

<div class="main-layout">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top px-4 shadow-sm">
            <a class="navbar-brand text-light fw-bold" href="/">HomeToHome</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item px-2">
                        <NavLink class="nav-link text-light" href="/" Match="NavLinkMatch.All">Home</NavLink>
                    </li>
                    <li class="nav-item px-2">
                        <NavLink class="nav-link text-light" href="login">Log In</NavLink>
                    </li>
                    <li class="nav-item px-2">
                        <NavLink class="nav-link text-light" href="ourservices">About Us</NavLink>
                    </li>
                    <li class="nav-item px-2">
                        <NavLink class="nav-link text-light" href="ourservices">Services</NavLink>
                    </li>
                    <li class="nav-item px-2">
                        <NavLink class="nav-link text-light" href="contact">Contact Us</NavLink>
                    </li>
                    <li class="nav-item px-2">
                        <NavLink class="nav-link text-light" href="feedback">Feedback</NavLink>
                    </li>

                </ul>
            </div>
        </nav>
    </header>

    <main class="mt-5 pt-5">
        @Body
    </main>
</div>
