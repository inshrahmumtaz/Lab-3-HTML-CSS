@page "/search-workers"
@using HomeToHome.Models
@inject WorkerService WorkerService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer
@using System.Net

<style>
    * {
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(to right, #ffffff, #f4f4f4);
        color: #212529;
        font-family: 'Segoe UI', sans-serif;
    }

    .container {
        max-width: 1200px;
        margin: 50px auto;
        padding: 20px;
    }

    h2 {
        text-align: center;
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 30px;
        color: #212529;
    }

    .search-container {
        max-width: 850px;
        margin: 0 auto 40px;
        padding: 30px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        text-align: center;
        color: #212529;
    }

        .search-container h3 {
            font-size: 30px;
            font-weight: bold;
            margin-bottom: 25px;
            color: #212529;
        }

    .search-box {
        display: flex;
        gap: 10px;
        align-items: center;
        justify-content: center;
    }

        .search-box input {
            width: 60%;
            padding: 12px 18px;
            border-radius: 30px;
            border: 1px solid #ccc;
            background-color: #f8f9fa;
            color: #212529;
            font-size: 16px;
            transition: 0.3s;
            outline: none;
        }

            .search-box input::placeholder {
                color: #888;
            }

            .search-box input:focus {
                border-color: #aaa;
                box-shadow: 0 0 8px rgba(0, 0, 0, 0.05);
            }

        .search-box button {
            background: linear-gradient(to right, black, black);
            border: none;
            border-radius: 30px;
            padding: 12px 25px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease-in-out;
        }

            .search-box button:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
            }

    .card-glass {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease-in-out;
        color: #212529;
        border: 1px solid #e0e0e0;
    }

        .card-glass:hover {
            transform: translateY(-5px);
        }

    .card-body {
        padding: 25px;
    }

    .card-title {
        font-size: 22px;
        font-weight: 600;
        color: #000;
    }

    .card-subtitle {
        font-size: 16px;
        color: #555;
        margin-bottom: 10px;
    }

    .skill-chip {
        background-color: black;
        color: #fff;
        border-radius: 12px;
        padding: 5px 12px;
        margin: 2px;
        font-size: 13px;
        display: inline-block;
    }

    .btn-request {
        margin-top: 15px;
        width: 100%;
        background: linear-gradient(to right, #2d2d2d, #2d2d2d);
        border: none;
        padding: 10px;
        border-radius: 25px;
        color: white;
        font-weight: bold;
        transition: all 0.3s ease-in-out;
    }

        .btn-request:hover {
            background: linear-gradient(to right, #2d2d2d, #2d2d2d);
            transform: scale(1.02);
        }

    .alert-info {
        margin: 20px auto;
        max-width: 600px;
        text-align: center;
        background-color: #e9f5ff;
        padding: 15px;
        border-radius: 10px;
        color: #0056b3;
        font-weight: 500;
        border: 1px solid #b8daff;
    }

    .btn-back {
        padding: 8px 15px;
        border: none;
        border-radius: 20px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease-in-out;
        background: linear-gradient(to right, #6c757d, #5a6268);
        color: white;
        margin-top: 20px;
        display: block;
        width: 200px;
        margin-left: auto;
        margin-right: auto;
    }

        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(108, 117, 125, 0.3);
        }
</style>

<div class="container">
    <h2>Search Workers for @Email</h2>

    <div class="search-container">
        <h3>Search Workers by Skill</h3>
        <div class="search-box">
            <input @bind="searchTerm" placeholder="Search by skill e.g. electrician, plumber..." />
            <button @onclick="Search">
                Search
            </button>
        </div>
    </div>

    @if (workers != null && workers.Any())
    {
        <div class="row px-4">
            @foreach (var worker in workers)
            {
                <div class="col-md-4 mb-4">
                    <div class="card card-glass h-100">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title">@worker.FirstName @worker.LastName</h5>
                                <h6 class="card-subtitle">@worker.Designation</h6>
                                <p><strong>City:</strong> @worker.City</p>
                                <p><strong>Email:</strong> @worker.Email</p>
                                <p><strong>Experience:</strong> @worker.Experience year(s)</p>
                                <p>
                                    <strong>Skills:</strong><br />
                                    @foreach (var skill in worker.Skills)
                                    {
                                        <span class="skill-chip">@skill</span>
                                    }
                                </p>
                            </div>
                            <button class="btn-request" @onclick="() => RequestService(worker.Email)">
                                Request Service
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (searched)
    {
        <div class="alert alert-info">No workers found with that skill.</div>
    }

    <button class="btn-back" @onclick="NavigateToDashboard">Back to Dashboard</button>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string Email { get; set; } = string.Empty;

    private string searchTerm;
    private List<Worker> workers = new();
    private bool searched = false;
    private bool _isInitialized;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Email))
        {
            var uri = new Uri(NavigationManager.Uri);
            Email = System.Web.HttpUtility.ParseQueryString(uri.Query).Get("email") ?? string.Empty;
        }

        _isInitialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isInitialized && firstRender)
        {
            if (string.IsNullOrEmpty(Email))
            {
                Email = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "userEmail") ?? string.Empty;
                StateHasChanged();
            }

            if (!string.IsNullOrEmpty(Email))
            {
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userEmail", Email);
            }
        }
    }

    private async Task Search()
    {
        searched = true;
        workers = await WorkerService.SearchWorkersBySkill(searchTerm);
    }

    private void RequestService(string workerEmail)
    {
        NavigationManager.NavigateTo($"/request-form?workerEmail={WebUtility.UrlEncode(workerEmail)}");
    }

    private void NavigateToDashboard()
    {
        NavigationManager.NavigateTo($"/user-page?email={Uri.EscapeDataString(Email)}");
    }
}