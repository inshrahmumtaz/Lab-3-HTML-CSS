@page "/"
@* Home page for Home2Home with fixed keyframes *@

<style>
    @@keyframes zoomSlow {
        0% {
            transform: scale(1);
        }

        100% {
            transform: scale(1.1);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translate(-50%, -60%);
        }

        to {
            opacity: 1;
            transform: translate(-50%, -50%);
        }
    }

    .home-banner {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
    }

        .home-banner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            animation: zoomSlow 20s infinite alternate;
        }

    .overlay {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        background: rgba(0, 0, 0, 0.5);
        padding: 40px;
        border-radius: 10px;
        text-align: center;
        max-width: 700px;
        animation: fadeIn 2s ease-in-out forwards;
        opacity: 0;
    }

    .main-title {
        font-size: 48px;
        font-weight: bold;
        margin-bottom: 10px;
    }

    .welcome-text {
        font-size: 18px;
        margin-bottom: 10px;
        letter-spacing: 1px;
    }

    .subtitle {
        font-size: 32px;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .description {
        font-size: 16px;
        margin-bottom: 25px;
    }

    .read-more-btn {
        background-color: #ff6600;
        color: white;
        padding: 12px 24px;
        text-decoration: none;
        font-weight: bold;
        border-radius: 5px;
        transition: background-color 0.3s, transform 0.3s;
        display: inline-block;
    }

        .read-more-btn:hover {
            background-color: #e65c00;
            transform: scale(1.05);
        }
</style>

<div class="home-banner">
    <img src="images/login.jpg" alt="Home Services Banner" />
    <div class="overlay">
        <h1 class="main-title">| Home Services |</h1>
        <p class="welcome-text">WELCOME TO HOME 2 HOME</p>
        <h2 class="subtitle">Best Home Services</h2>
        <p class="description">
            Busy Home Owners can always find a maid company to do the all house cleaning work for them.
        </p>
        <a href="/about" class="read-more-btn">Read More</a>
    </div>
</div>
