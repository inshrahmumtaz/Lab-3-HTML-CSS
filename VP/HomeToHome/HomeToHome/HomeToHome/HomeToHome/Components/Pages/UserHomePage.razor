@page "/user-page"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<style>
    /* Full viewport height & width, center content */
    body, html {
        height: 100%;
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .page-wrapper {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
    }

    .dashboard-container {
        max-width: 480px;
        width: 100%;
        padding: 40px 30px;
        background-color: #fff;
        border-radius: 24px;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
        text-align: center;
        transition: transform 0.3s ease;
    }

        .dashboard-container:hover {
            transform: translateY(-6px);
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.15);
        }

    .dashboard-title {
        font-size: 2.25rem; /* 36px */
        font-weight: 700;
        color: #111;
        margin-bottom: 40px;
    }

    .dashboard-button {
        width: 100%;
        font-size: 1.1rem;
        padding: 16px 0;
        border-radius: 50px;
        font-weight: 600;
        border: 2px solid #111;
        color: #111;
        background-color: #fff;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-bottom: 20px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

        .dashboard-button:last-child {
            margin-bottom: 0;
        }

        .dashboard-button:hover {
            background-color: #111;
            color: #fff;
            box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
            transform: translateY(-3px);
        }
</style>

<div class="page-wrapper">
    <div class="dashboard-container">
        <h3 class="dashboard-title">Welcome to the User Dashboard, @Email</h3>

        <button class="dashboard-button" @onclick="NavigateToSearch">
            Search Services
        </button>
        <button class="dashboard-button" @onclick="NavigateToRequests">
            Review Requests
        </button>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string Email { get; set; } = string.Empty;

    private bool _isInitialized;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Email))
        {
            var uri = new Uri(NavigationManager.Uri);
            Email = System.Web.HttpUtility.ParseQueryString(uri.Query).Get("email") ?? string.Empty;
        }

        _isInitialized = true;
        Console.WriteLine($"UserHomePage OnInitializedAsync with email: {Email}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isInitialized && firstRender)
        {
            if (string.IsNullOrEmpty(Email))
            {
                Email = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "userEmail") ?? string.Empty;
                StateHasChanged();
            }

            if (!string.IsNullOrEmpty(Email))
            {
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userEmail", Email);
            }

            Console.WriteLine($"UserHomePage OnAfterRenderAsync with email: {Email}");
        }
    }

    private void NavigateToSearch()
    {
        NavigationManager.NavigateTo($"/search-workers?email={Uri.EscapeDataString(Email)}");
    }

    private void NavigateToRequests()
    {
        NavigationManager.NavigateTo($"/review-requests?email={Uri.EscapeDataString(Email)}");
    }
}