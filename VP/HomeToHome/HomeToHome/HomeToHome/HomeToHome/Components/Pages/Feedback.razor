@page "/feedback"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using HomeToHome.Models
@using Microsoft.AspNetCore.Components.Forms
@inject HomeToHome.Services.FeedbackService FeedbackService


<style>
    .feedback-container {
        display: flex;
        height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .image-side {
        flex: 1;
        background: url('/images/Feedback.jpg') no-repeat center center/cover;
    }

    .form-side {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: white;
        padding: 40px;
    }

    .form-section {
        width: 100%;
        max-width: 400px;
        background-color: rgba(255, 255, 255, 0.95);
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0px 5px 20px rgba(0, 0, 0, 0.2);
        animation: slideUp 1s ease-in-out;
    }

        .form-section h2 {
            margin-bottom: 20px;
            font-size: 28px;
            color: #333;
            text-align: center;
        }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border-radius: 25px;
        border: 1px solid #ccc;
        transition: 0.3s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: #f2994a;
            box-shadow: 0 0 8px rgba(242, 153, 74, 0.6);
        }

    .btn-submit {
        width: 100%;
        background-color: #2d2d2d;
        color: white;
        border: none;
        border-radius: 25px;
        padding: 12px;
        font-size: 16px;
        transition: 0.3s ease;
    }

        .btn-submit:hover {
            background-color: #000;
            transform: scale(1.02);
        }

    .alert-success {
        background-color: #d4edda;
        color: #155724;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 15px;
        text-align: center;
    }
</style>

<div class="feedback-container">
    <div class="image-side"></div>

    <div class="form-side">
        <div class="form-section">
            <h2>We Value Your Feedback</h2>
            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert-success">@successMessage</div>
            }


            <EditForm Model="@feedbackModel" OnValidSubmit="HandleSubmit" FormName="FeedbackForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-group">
                    <InputText @bind-Value="feedbackModel.Name" class="form-control" placeholder="Your Name" />
                    <ValidationMessage For="@(() => feedbackModel.Name)" />
                </div>

                <div class="form-group">
                    <InputText @bind-Value="feedbackModel.Email" class="form-control" placeholder="Your Email" />
                    <ValidationMessage For="@(() => feedbackModel.Email)" />
                </div>

                <div class="form-group">
                    <InputTextArea @bind-Value="feedbackModel.Message" class="form-control" placeholder="Your Feedback" rows="4" />
                    <ValidationMessage For="@(() => feedbackModel.Message)" />
                </div>

                <button type="submit" class="btn-submit">SUBMIT FEEDBACK</button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private FeedbackModel feedbackModel = new();
    private string successMessage;

    private async Task HandleSubmit()
    {
        var feedback = new HomeToHome.Models.Feedback
            {
                Name = feedbackModel.Name,
                Email = feedbackModel.Email,
                Message = feedbackModel.Message,
                SubmittedAt = DateTime.UtcNow
            };

        await FeedbackService.SaveFeedbackAsync(feedback);
        successMessage = "Thank you for your feedback!";
        feedbackModel = new(); // reset form
    }

    public class FeedbackModel
    {
        [Required(ErrorMessage = "Name is required")]
        public string Name { get; set; }

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email")]
        public string Email { get; set; }

        [Required(ErrorMessage = "Feedback is required")]
        public string Message { get; set; }
    }
}
