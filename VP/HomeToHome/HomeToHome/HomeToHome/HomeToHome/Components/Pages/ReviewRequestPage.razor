@page "/review-requests"
@using HomeToHome.Models
@inject UserService UserService
@inject RequestService RequestService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

<style>
    * {
        box-sizing: border-box;
    }

    body {
        background: linear-gradient(to right, #f4f4f4, #ffffff);
        color: #212529;
        font-family: 'Segoe UI', sans-serif;
    }

    .container {
        max-width: 1200px;
        margin: 50px auto;
        padding: 20px;
    }

    .table-container {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 15px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        padding: 20px;
    }

    h2 {
        text-align: center;
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 30px;
        color: #212529;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        font-size: 16px;
    }

        .table th, .table td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #e0e0e0;
        }

        .table th {
            background: linear-gradient(to right, #2d2d2d, #2d2d2d);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
        }

        .table td {
            color: #212529;
        }

        .table tr:hover {
            background-color: #f8f9fa;
        }

    .btn-edit, .btn-cancel, .btn-back {
        padding: 8px 15px;
        border: none;
        border-radius: 20px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease-in-out;
    }

    .btn-edit {
        background: linear-gradient(to right, #007bff, #0056b3);
        color: white;
        margin-right: 10px;
    }

        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 123, 255, 0.3);
        }

    .btn-cancel {
        background: linear-gradient(to right, #dc3545, #b02a37);
        color: white;
    }

        .btn-cancel:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3);
        }

    .btn-back {
        background: linear-gradient(to right, #6c757d, #5a6268);
        color: white;
        margin-top: 20px;
        display: block;
        width: 200px;
        margin-left: auto;
        margin-right: auto;
    }

        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(108, 117, 125, 0.3);
        }

    .alert-info {
        margin: 20px auto;
        max-width: 600px;
        text-align: center;
        background-color: #e9f5ff;
        padding: 15px;
        border-radius: 10px;
        color: #0056b3;
        font-weight: 500;
        border: 1px solid #b8daff;
    }
</style>

<div class="container">
    <div class="table-container">
        <h2>Review Service Requests for @Email</h2>

        @if (requests != null && requests.Any())
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>User Email</th>
                        <th>Worker Email</th>
                        <th>Service Type</th>
                        <th>Preferred Date</th>
                        <th>Preferred Time</th>
                        <th>City</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in requests)
                    {
                        <tr>
                            <td>@request.Id</td>
                            <td>@request.UserEmail</td>
                            <td>@request.WorkerEmail</td>
                            <td>@request.ServiceType</td>
                            <td>@(request.PreferredDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                            <td>@(request.PreferredTime ?? "N/A")</td>
                            <td>@request.City</td>
                            <td>@request.RequestStatus</td>
                            <td>
                                <button class="btn-edit" @onclick="() => EditRequest(request.Id)">Edit</button>
                                <button class="btn-cancel" @onclick="() => CancelRequest(request.Id)">Cancel</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="alert-info">No service requests found for @Email.</div>
        }

        <button class="btn-back" @onclick="NavigateToDashboard">Back to Dashboard</button>
    </div>
</div>

@code {
    private List<ServiceRequest> requests = new();
    [Parameter]
    [SupplyParameterFromQuery]
    public string Email { get; set; } = string.Empty;

    private bool _isInitialized;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Email))
        {
            var uri = new Uri(NavigationManager.Uri);
            Email = System.Web.HttpUtility.ParseQueryString(uri.Query).Get("email") ?? string.Empty;
        }

        if (!string.IsNullOrEmpty(Email))
        {
            requests = await RequestService.GetRequestsByUserEmailAsync(Email);
        }

        _isInitialized = true;
        Console.WriteLine($"ReviewRequests OnInitializedAsync with email: {Email}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isInitialized && firstRender)
        {
            if (string.IsNullOrEmpty(Email))
            {
                Email = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "userEmail") ?? string.Empty;
                if (!string.IsNullOrEmpty(Email))
                {
                    requests = await RequestService.GetRequestsByUserEmailAsync(Email);
                    StateHasChanged();
                }
            }

            if (!string.IsNullOrEmpty(Email))
            {
                await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "userEmail", Email);
            }

            Console.WriteLine($"ReviewRequests OnAfterRenderAsync with email: {Email}");
        }
    }

    private void NavigateToDashboard()
    {
        NavigationManager.NavigateTo($"/user-page?email={Uri.EscapeDataString(Email)}");
    }

    private void EditRequest(int requestId)
    {
        NavigationManager.NavigateTo($"/edit-request?requestId={requestId}&email={Uri.EscapeDataString(Email)}");
    }

    private async Task CancelRequest(int requestId)
    {
        var request = requests.FirstOrDefault(r => r.Id == requestId);
        if (request != null)
        {
            request.RequestStatus = "Cancelled";
            await RequestService.UpdateRequestAsync(request);
            requests = await RequestService.GetRequestsByUserEmailAsync(Email);
            StateHasChanged();
        }
    }
}